# ---------------------------------------------------------------
# Generated protobuf - language outputs
# ---------------------------------------------------------------
gen/

# Safety net - in case generation lands outside gen/
**/*.pb.go
**/*.pb.gw.go
**/*_grpc.pb.go

# C#
**/*.pb.cs
**/*Grpc.cs

# TypeScript / JavaScript
**/*_pb.js
**/*_pb.d.ts
**/*_pb_service.js
**/*_pb_service.d.ts
**/*.pb.ts

# Python
**/*_pb2.py
**/*_pb2.pyi
**/*_pb2_grpc.py

# Ruby
**/*_pb.rb
**/*_services_pb.rb

# Java / Kotlin
# (usually in src/main/java or build/, covered by build/)
build/
*.class

# Rust
# (usually in src/generated or OUT_DIR, hard to glob safely)
# recommend explicit path if you add Rust output